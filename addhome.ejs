<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/home.css">
    <title>Add User Profile</title>
</head>
<body>
    <div class="navbar">
        <h1>Add New User</h1>
        <%= editing ? "edit the home" : "add new home" %>
        <div class="nav-links">
            <a href="/" class="btn-nav">Home</a>
            <a href="/user" class="btn-nav">Users</a>
        </div>
    </div>

    <div class="container">
        <div class="form-container">
            <div class="form-card">
                <h2> <%= editing ? "edit the home" : "add new home" %></h2>
                <p class="form-subtitle">Fill in your details below</p>
                
                <form action="/host/<%= editing ? 'edit' : 'contact_us' %>" method="POST">
                    <input type="hidden" name="id" value="<%= editing ? userfound._id : '' %>">

                    <div class="form-group">
                        <label for="username">Full Name</label>
                        <input type="text" id="username" name="username" value="<%= editing ? userfound.username : '' %>"
 placeholder="Enter your full name" required>
                    </div>

                    <div class="form-group">

                        <div class="mob_no">
                            <label for="mob_no">mob_no </label>
                            <input type="text" id="mob_no" name="mob_no" value="<%= editing ? userfound.mob_no : '' %>"
 placeholder="Enter your mob_no" required>
                        </div>
                      
                    </div>
                    <div class="form-group">
                    <div class="city">
                        <label for="city">City</label>
                        <input type="text" id="city" name="city" value="<%= editing ? userfound.city : '' %>"
 placeholder="Enter your city" required>
                    </div>
                    </div>
                    <div class="form-group">
                    <div class="price">
                        <label for="price">price</label>
                        <input type="text" id="price" name="price" value="<%= editing ? userfound.price : '' %>"
 placeholder="Enter your price per night" required>
                    </div>
                    </div>

                    <button type="submit" class="btn-submit"><%= editing ? 'Update' : 'Submit' %></button>
                    <a href="/" class="btn-cancel">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>